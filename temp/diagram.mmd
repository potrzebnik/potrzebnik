classDiagram
    direction LR

%% ── Core: User & Roles ──────────────────────

    class User {
        +id: int [PK]
        +email: String
        +passwordHash: String
        +role: UserRole ~DONOR | ORGANIZATION_ADMIN~
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

    class Donor {
        +id: int [PK]
        +userId: int [FK]
        +name: String
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

    class Organization {
        +id: int [PK]
        +userId: int [FK]
        +name: String
        +krs: String
        +addressId: int [FK]
        +categoryId: int [FK]
        +phoneNumber: String
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

%% ── Need ────────────────────────────────────

    class Need {
        +id: int [PK]
        +description: String
        +price: Number
        +organizationId: int [FK]
        +donee: String
        +item: String
        +addressId: int [FK]
        +expiry: Date
        +photo?: String
        +status: NeedStatus ~ACTIVE | FULFILLED | EXPIRED~
        +categoryId: int [FK]
        +type: NeedType ~ONE_TIME~
        +important: boolean
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

%%    class RecurringNeed {
%%        +id: UUID [PK]
%%        +needId: UUID [FK]
%%        +intervalDays: Integer
%%        +nextOccurrence: Date
%%        +endDate?: Date
%%        +createdAt: Timestamp
%%        +updatedAt: Timestamp
%%    }

    class NeedStatusHistory {
        +id: int [PK]
        +needId: int [FK]
        +status: NeedStatus
        +changedById: int [FK]
        +createdAt: Timestamp
    }

    class NeedCategory {
        +id: int [PK]
        +name: String
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

%% ── Donation ────────────────────────────────

    class Donation {
        +id: int [PK]
        +donorId: int [FK]
        +needId: int [FK]
        +status: DonationStatus ~BOOKED | FULFILLED | CANCELLED~
        +bookedAt: Timestamp
        +fulfilledAt?: Timestamp
        +updatedAt: Timestamp
    }

    class DonorFavouriteNeed {
        +donorId: int [PK, FK]
        +needId: int [PK, FK]
    }

%% ── Shared ──────────────────────────────────

    class OrganizationCategory {
        +id: int [PK]
        +name: String
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

    class Address {
        +id: int [PK]
        +city: String
        +street: String
        +building: String
        +apartment?: String
        +zipCode: String
        +createdAt: Timestamp
        +updatedAt: Timestamp
    }

%% ── Relations ───────────────────────────────

    Donor --> User : userId
    Organization --> User : userId

    Need --> Organization : organizationId
    Need --> NeedCategory : categoryId
    Need --> Address : addressId

%%    RecurringNeed --> Need : needId
    NeedStatusHistory --> Need : needId
    NeedStatusHistory --> User : changedById

    Organization --> Address : addressId
    Organization --> OrganizationCategory : categoryId

    Donation --> Donor : donorId
    Donation --> Need : needId

    DonorFavouriteNeed --> Donor : donorId
    DonorFavouriteNeed --> Need : needId
